{
  "name": "textmagic",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:dev-24-bookworm",
  // "image": "node:24-bookworm",
  "runArgs": [
    "--name=textmagic-dev"
  ],
  "remoteUser": "node",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "mounts": [
    "source=${localWorkspaceFolderBasename}-node_modules,target=${containerWorkspaceFolder}/node_modules,type=volume",
    "source=devScripts,target=/workspaces/dev_scripts,type=volume"
  ],
  // "onCreateCommand": "sudo chown -R node:node /workspaces/${localWorkspaceFolderBasename}/node_modules && sudo chown -R node:node /workspaces/dev_scripts",
  "postCreateCommand": "/workspaces/dev_scripts/post_create.sh",
  "postStartCommand": "/workspaces/dev_scripts/post_start.sh",
  "forwardPorts": [
    5173,
    4173
  ],
  "portsAttributes": {
    "5173": {
      "label": "Vite dev server",
      "onAutoForward": "silent",
      "protocol": "http"
    },
    "4173": {
      "label": "Vite preview",
      "onAutoForward": "silent"
    }
  },
  "containerEnv": {
    "CHOKIDAR_USEPOLLING": "true"
  },
  "customizations": {
    "vscode": {
      "extensions": [],
      "settings": {
        "eslint.validate": [
          "javascript",
          "javascriptreact",
          "typescript",
          "typescriptreact"
        ]
      }
    }
  }
}